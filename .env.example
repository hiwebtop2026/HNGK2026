# ============================================
# Supabase 配置（前端使用，VITE_ 前缀暴露给客户端）
# ============================================
# anon key 是公开安全的，配合RLS使用；service_role 严禁前端使用
# 获取方式：登录 supabase.com → 选择项目 → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=替换为你的anon_key

# ============================================
# Resend 邮件服务配置（用于发送验证码）
# ============================================
# 获取方式：登录 resend.com → API Keys
# 免费版：3000封/月
VITE_RESEND_API_KEY=替换为你的Resend API Key
VITE_RESEND_FROM_EMAIL=no-reply@your-domain.com

# ============================================
# Python脚本使用（仅服务端，不暴露给前端）
# ============================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=替换为你的service_role_key（在Supabase控制台轮换后填入）
SUPABASE_ANON_KEY=替换为你的anon_key

# ============================================
# 直连数据库脚本使用（psycopg2，仅服务端）
# ============================================
# 数据库直连URL，格式：postgresql://postgres.<ref>:<password>@<host>:6543/postgres
# 密码在 Supabase Dashboard → Settings → Database → Connection string 中获取
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
# 数据库密码（供 psycopg2 直连脚本使用）
SUPABASE_DB_PASSWORD=your-db-password
